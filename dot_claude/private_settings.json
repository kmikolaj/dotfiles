{
  "permissions": {
    "deny": [
      "Bash(rm:*)",
      "Bash(rmdir:*)",
      "Bash(mv:*)",
      "Bash(dd:*)",
      "Bash(mkfs:*)",
      "Bash(fdisk:*)",
      "Bash(sudo:*)",
      "Bash(su:*)",
      "Bash(chmod:*)",
      "Bash(chown:*)",
      "Bash(apt-get:*)",
      "Bash(apt:*)",
      "Bash(snap:*)",
      "Bash(pip install:*)",
      "Bash(git push --force:*)",
      "Bash(git push -f:*)",
      "Bash(git push --force-with-lease:*)",
      "Bash(iptables:*)",
      "Bash(ip link:*)",
      "Bash(ifconfig:*)",
      "Bash(curl:*)",
      "Bash(wget:*)",
      "Read(.env)",
      "Read(.env.*)",
      "Read(*secrets*)",
      "Read(*password*)",
      "Read(*private_key*)"
    ],
    "allowedTools": [
      "Read",
      "Glob",
      "Grep",
      "LS",
      "WebFetch",
      "TodoRead",
      "TodoWrite",
      "Write",
      "Edit",
      "MultiEdit",
      "Bash(git log:*)",
      "Bash(git diff:*)",
      "Bash(git status:*)",
      "Bash(git show:*)",
      "Bash(git blame:*)",
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(git checkout:*)",
      "Bash(git branch:*)",
      "Bash(git stash:*)",
      "Bash(git fetch:*)",
      "Bash(git pull:*)",
      "Bash(git push:*)",
      "Bash(make:*)",
      "Bash(cmake:*)",
      "Bash(qmake:*)",
      "Bash(ninja:*)",
      "Bash(g++:*)",
      "Bash(gcc:*)",
      "Bash(clang++:*)",
      "Bash(clang:*)",
      "Bash(objdump:*)",
      "Bash(nm:*)",
      "Bash(ldd:*)",
      "Bash(readelf:*)",
      "Bash(moc:*)",
      "Bash(uic:*)",
      "Bash(rcc:*)",
      "Bash(qdbusxml2cpp:*)",
      "Bash(ls:*)",
      "Bash(find:*)",
      "Bash(cat:*)",
      "Bash(head:*)",
      "Bash(tail:*)",
      "Bash(grep:*)",
      "Bash(file:*)",
      "Bash(stat:*)",
      "Bash(du:*)",
      "Bash(df:*)",
      "Bash(wc:*)",
      "Bash(udevadm:*)",
      "Bash(lsblk:*)",
      "Bash(lspci:*)",
      "Bash(lsusb:*)",
      "Bash(dmesg:*)",
      "Bash(journalctl:*)",
      "Bash(systemctl status:*)",
      "Bash(dpkg:*)",
      "Bash(dpkg-query:*)",
      "Bash(apt-cache:*)",
      "Bash(pkg-config:*)",
      "Bash(ssh:*)",
      "Bash(scp:*)",
      "Bash(rsync:*)",
      "Bash(gdb:*)",
      "Bash(valgrind:*)",
      "Bash(strace:*)",
      "Bash(ltrace:*)",
      "Bash(openssl:*)",
      "Bash(python3:*)",
      "Bash(python:*)"
    ]
  },
  "model": "sonnet",
  "statusLine": {
    "type": "command",
    "command": "python3 ~/.claude/statusline.py"
  },
  "enabledPlugins": {
    "clangd-lsp@claude-plugins-official": true,
    "rust-analyzer-lsp@claude-plugins-official": true
  },
  "syntaxHighlightingDisabled": false,
  "skipDangerousModePermissionPrompt": false,
  "preferredNotifChannel": "terminal_bell",
  "hooks": {
    "UserPromptSubmit": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "date +%s > /tmp/claude_start",
            "async": true
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "s=$(cat /tmp/claude_start 2>/dev/null || echo 0); e=$(($(date +%s)-s)); [ $e -gt 120 ] && notify-send 'Claude' 'Done'",
            "async": true
          }
        ]
      }
    ]
  }
}
