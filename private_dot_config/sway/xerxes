# outputs
output eDP-1 {
    position 1680 0
    resolution 2560x1600@120Hz
    scale 2
}

output HDMI-A-1 {
    position 0 0
    #resolution 1920x1200@60Hz
    resolution 1680x1050@60Hz
}

# if both screen connected external is primary
workspace 1 output HDMI-A-1 eDP-1

# focus external screen
focus output HDMI-A-1
# focus laptop screen if connected
focus output eDP-1

# toggle internal output on lid open/close
bindswitch --locked lid:off output eDP-1 enable
bindswitch --locked lid:on output eDP-1 disable

# brightness
bindsym XF86MonBrightnessUp exec --no-startup-id brightnessctl -q -c backlight -n1 set 5%+
bindsym XF86MonBrightnessDown exec --no-startup-id brightnessctl -q -c backlight -n1 set 5%-

# audio
bindsym XF86AudioRaiseVolume exec --no-startup-id wpctl set-volume -l 1.0 @DEFAULT_AUDIO_SINK@ 5%+
bindsym XF86AudioLowerVolume exec --no-startup-id wpctl set-volume @DEFAULT_AUDIO_SINK@ 5%-
bindsym XF86AudioMute exec --no-startup-id wpctl set-mute @DEFAULT_AUDIO_SINK@ toggle
bindsym XF86AudioMicMute exec --no-startup-id wpctl set-mute @DEFAULT_AUDIO_SOURCE@ toggle

# paste
bindsym Mod4+v exec --no-startup-id wtype -M shift -k Insert -m shift

