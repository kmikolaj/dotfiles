default partial xkb_symbols "cutcopypaste" {
	replace key <AB02> {
		type[Group1]= "FOUR_LEVEL_ALPHABETIC_SUPER",
		symbols[Group1]= [x,X,zacute,Zacute,XF86Cut]
	};
	replace key <AB03> {
		type[Group1]= "FOUR_LEVEL_ALPHABETIC_SUPER",
		symbols[Group1]= [c,C,cacute,Cacute,XF86Copy]
	};
	replace key <AB04> {
		type[Group1]= "FOUR_LEVEL_SEMIALPHABETIC_SUPER",
		symbols[Group1]= [v,V,doublelowquotemark,leftsinglequotemark,XF86Paste]
	};
};
